# ============================================================
# Living Atlas AI Platform — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
LA_PG_HOST=postgres
LA_PG_PORT=5432
LA_PG_DATABASE=living_atlas
LA_PG_USER=living_atlas
LA_PG_PASSWORD=living_atlas

# --- Redpanda / Kafka ---
LA_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# --- Redis ---
LA_REDIS_URL=redis://redis:6379/0

# --- Weaviate ---
LA_WEAVIATE_URL=http://weaviate:8080
LA_WEAVIATE_API_KEY=

# --- Prefect ---
LA_PREFECT_API_URL=http://prefect-server:4200/api

# --- LLM API Keys (Required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Default LLM provider for enrichment (gemini | claude | openai)
LLM_PROVIDER=gemini

# --- STT API Keys (Required for fallback) ---
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# --- Google Cloud (for STT) ---
# Path to GCP service account JSON credentials
GOOGLE_APPLICATION_CREDENTIALS=./infrastructure/secrets/gcp-credentials.json

# --- Observability ---
LA_LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin