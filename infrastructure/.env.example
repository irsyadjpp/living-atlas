# ============================================================
# Living Atlas — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
LA_PG_HOST=postgres
LA_PG_PORT=5432
LA_PG_DATABASE=living_atlas
LA_PG_USER=living_atlas
LA_PG_PASSWORD=living_atlas

# --- Redpanda / Kafka ---
LA_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# --- Redis ---
LA_REDIS_URL=redis://redis:6379/0

# --- Weaviate ---
LA_WEAVIATE_URL=http://weaviate:8080
LA_WEAVIATE_API_KEY=

# --- LLM API Keys (Required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Default LLM provider (gemini | claude | openai)
LLM_PROVIDER=gemini

# --- Observability ---
LA_LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin